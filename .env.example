# Copy to .env and/or .env.local in this folder (both are loaded; .env.local overrides).
# Microsoft Entra ID — Web app (confidential client + client secret)
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
# Tenant GUID or common
AUTH_MICROSOFT_ENTRA_ID_TENANT=

# Must match Azure → Authentication → Web → Redirect URI (exactly)
# Local dev with Vite: browser hits localhost:5173, proxy forwards /api → this server
OAUTH_REDIRECT_URI=http://localhost:5173/api/oauth/callback

# Where to send the browser after login (Skyport-Web)
FRONTEND_ORIGIN=http://localhost:5173

# Sign cookies / session JWT (generate: openssl rand -hex 32)
SESSION_SECRET=

PORT=3001
