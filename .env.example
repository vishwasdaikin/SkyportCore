# Copy to .env and/or .env.local (both loaded; .env.local non-empty keys override).

AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_TENANT=

# Local: Vite proxy — redirect URI through :5173/api
OAUTH_REDIRECT_URI=http://localhost:5173/api/oauth/callback
FRONTEND_ORIGIN=http://localhost:5173

# Vercel Core (see repo README): use Core’s own URL for OAuth callback, Web app URL for CORS + return:
# OAUTH_REDIRECT_URI=https://skyport-core.vercel.app/oauth/callback
# FRONTEND_ORIGIN=https://your-skyport-web.vercel.app
# FRONTEND_ORIGINS=  (optional extra CORS origins, comma-separated)

SESSION_SECRET=
PORT=3001
