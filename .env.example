# Copy to .env and/or .env.local (both loaded; .env.local non-empty keys override).

AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
# GUID or common only — not the full https://login.../v2.0 URL (causes 404 if doubled)
AUTH_MICROSOFT_ENTRA_ID_TENANT=

# Local: Vite proxy — redirect URI through :5173/api
OAUTH_REDIRECT_URI=http://localhost:5173/api/oauth/callback
FRONTEND_ORIGIN=http://localhost:5173

# Vercel production (see Skyport-Web docs/VERCEL_URLS.md):
# OAUTH_REDIRECT_URI=https://skyport-core.vercel.app/oauth/callback
# FRONTEND_ORIGIN=https://skyport-home.vercel.app
# FRONTEND_ORIGINS=  (optional: preview web URLs, comma-separated)
# Preview Core: OAUTH_REDIRECT_URI must be https://<that-preview-host>/oauth/callback and listed in Azure.

# Optional: login | select_account — helps bust stuck Microsoft SSO (see Skyport-Web docs/TROUBLESHOOTING_SIGNIN.md)
# OAUTH_PROMPT=login

SESSION_SECRET=
PORT=3001
